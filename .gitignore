# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio build artifacts
/android/app/debug
/android/app/profile
/android/app/release

# Android signing credentials - NEVER commit keystores
android/key.properties
android/app/*.jks
android/app/*.keystore

# Flutter environment files - NEVER commit real env files
.env
.env.*

# Crypto/TLS credentials
*.pem
*.key
*.p12
*.pfx

# Firebase Service Account keys - NEVER commit these
serviceAccountKey.json
firebase-adminsdk.json
firebase-service-account.json
*-firebase-adminsdk-*.json

# GoogleService-Info.plist (iOS) - does NOT need to be tracked for Android-only builds
# IMPORTANT: android/app/google-services.json IS tracked (required for Firebase on Android)
GoogleService-Info.plist

# Backend dependencies
node_modules/
npm-debug.log*
yarn-error.log

# OS Files
.DS_Store
Thumbs.db
